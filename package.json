{
  "name": "codeappjsext",
  "displayName": "CodeAppJS",
  "description": "VS Code wrapper for Power Apps Code App workflows using codeapp-js-cli",
  "version": "2.0.5",
  "icon": "codeapp-js.png",
  "publisher": "PowerDevBox",
  "repository": "https://github.com/wyattdave/Codeapp-Ext",
  "engines": {
    "vscode": "^1.95.0"
  },
  "os": [
    "win32"
  ],
  "categories": [
    "Other"
  ],
  "keywords": [
    "power platform",
    "code apps",
    "dataverse",
    "codeapp-js-cli",
    "cap",
    "Power Apps"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeappjsext.setup",
        "title": "CodeAppJS: Setup Project",
        "icon": "$(tools)"
      },
      {
        "command": "codeappjsext.import",
        "title": "CodeAppJS: Import Code App",
        "icon": "$(cloud-download)"
      },
      {
        "command": "codeappjsext.auth",
        "title": "CodeAppJS: Authenticate",
        "icon": "$(account)"
      },
      {
        "command": "codeappjsext.environment",
        "title": "CodeAppJS: Change Environment",
        "icon": "$(globe)"
      },
      {
        "command": "codeappjsext.connections",
        "title": "CodeAppJS: Add Dataverse Schema",
        "icon": "$(plug)"
      },
      {
        "command": "codeappjsext.table",
        "title": "CodeAppJS: Add Dataverse Table",
        "icon": "$(table)"
      },
      {
        "command": "codeappjsext.flowSchema",
        "title": "CodeAppJS: Add Flow Schema",
        "icon": "$(references)"
      },
      {
        "command": "codeappjsext.mockup",
        "title": "CodeAppJS: Open Mockup",
        "icon": "$(device-desktop)"
      },
      {
        "command": "codeappjsext.debugger",
        "title": "CodeAppJS: Toggle Debugger",
        "icon": "$(debug-alt-small)"
      },
      {
        "command": "codeappjsext.deploy",
        "title": "CodeAppJS: Deploy",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "codeappjsext.toggleButtonVisibility",
        "title": "CodeAppJS: Toggle Button Visibility",
        "icon": "$(eye)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "codeappjsext.debugger",
          "when": "codeappjsext.buttonsVisible",
          "group": "navigation@1"
        },
        {
          "command": "codeappjsext.deploy",
          "when": "codeappjsext.buttonsVisible",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "key": "ctrl+alt+c",
        "command": "multiCommand.maximizeCopilot"
      }
    ],
    "chatAgents": [
      {
        "path": "./resources/AI/AI/codeapp.agent.md",
        "sessionTypes": [
          "local"
        ]
      }
    ],
    "chatSkills": [
      {
        "path": "./resources/AI/AI/skills/autoreview/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/connections/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/dataverse/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/environment-variables/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/frontend-design/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/jira/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/keyvault/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/logicflows/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/office365-groups/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/office365-outlook/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/office365-users/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/sharepoint/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/sql/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/start/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      },
      {
        "path": "./resources/AI/AI/skills/teams/SKILL.md",
        "sessionTypes": [
          "local"
        ]
      }
    ]
  },
  "scripts": {
    "lint": "eslint src --ext js",
    "package": "vsce package",
    "package:win32-x64": "vsce package --target win32-x64"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1"
  },
  "dependencies": {
    "codeapp-js-cli": "^1.0.3"
  }
}
