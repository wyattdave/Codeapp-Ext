{
  "name": "codeapp-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone JS CLI for Power Apps Code Apps. Wraps @microsoft/power-apps-actions and removes the dependency on @microsoft/power-apps-cli / npx power-apps.",
