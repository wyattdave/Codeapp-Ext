  },
  "dependencies": {
    "@azure/msal-node": "^3.6.3",
    "@microsoft/power-apps-actions": "^1.4.0",
    "commander": "^10.0.1",
    "open": "^8.4.0"
  },
  "engines": {
    "node": ">=22"
  }
}
